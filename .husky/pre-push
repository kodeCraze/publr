#!/usr/bin/env sh

echo "Running build on clean HEAD..."

STASHED=0

if ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  git stash push -u -q -m "pre-push-backup"
  STASHED=1
fi

pnpm build
STATUS=$?

if [ "$STASHED" -eq 1 ]; then
  git stash pop -q
fi

[ $STATUS -eq 0 ] || {
  echo "Build failed. Push rejected."
  exit 1
}